{
    "name": "squiggle-muter",
    "displayName": "Squiggle Muter",
    "description": "Hide annoying squiggles in JavaScript or TypeScript files",
    "version": "0.0.5",
    "type": "module",
    "publisher": "krave",
    "license": "MIT",
    "scripts": {
        "generate:vsix": "vsce package --follow-symlinks",
        "publish:marketplace": "vsce publish --follow-symlinks && npm version patch --no-git-tag-version",
        "compress:images": "node scripts/compress-images.js"
    },
    "icon": "images/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/krave1986/squiggle-muter.git"
    },
    "categories": [
        "Linters"
    ],
    "keywords": [
        "typescript",
        "javascript",
        "squiggle",
        "diagnostic",
        "suppress"
    ],
    "engines": {
        "vscode": "^1.75.0"
    },
    "activationEvents": [
        "onLanguage:javascript"
    ],
    "main": "./extension.js",
    "contributes": {
        "typescriptServerPlugins": [
            {
                "name": "squiggle-muter-plugin",
                "enableForWorkspaceTypeScriptVersions": true
            }
        ],
        "configuration": {
            "title": "Squiggle Muter",
            "properties": {
                "squiggleMuter.suppressedCodes": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "default": [],
                    "description": "List of TypeScript diagnostic codes to suppress."
                }
            }
        }
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vscode/vsce": "^3.9.1",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "prettier": "^3.8.1",
        "sharp": "^0.34.5"
    },
    "dependencies": {
        "squiggle-muter-plugin": "file:plugin"
    }
}
